"Jpsi_debug_TPCTOF0_rejBadTOF": {
"type": "AnalysisCompositeCut",
"useAND": true,
"AddCut1": {
"type": "AnalysisCut",
"AddCut1": { "var": "kP", "cutLow": 1.0, "cutHigh": 1000.0 }
},
"AddCut2": {
"type": "AnalysisCut",
"AddCut1": { "var": "kEta", "cutLow": -0.9, "cutHigh": 0.9 }
},
"AddCut3": {
"type": "AnalysisCut",
"AddCut1": { "var": "kTPCchi2", "cutLow": 0.0, "cutHigh": 4.0 }
},
"AddCut4": {
"type": "AnalysisCut",
"AddCut1": { "var": "kTPCncls", "cutLow": 70, "cutHigh": 161.0 }
},
"AddCut5": {
"type": "AnalysisCut",
"AddCut1": { "var": "kIsSPDfirst", "cutLow": 0.5, "cutHigh": 1.5 }
},
"AddCut6": {
  "type": "AnalysisCut",
  "AddCut1": {
    "var": "kTrackDCAxy",
    "cutLowFuncExpr": "-0.0105 - 0.035/pow(x, 1.1)",
    "cutHighFuncExpr": "0.0105 + 0.035/pow(x, 1.1)"
  }
},
"AddCut7": {
  "type": "AnalysisCut",
  "AddCut1": { "var": "kTrackDCAz", "cutLow": -0.5, "cutHigh": 0.5 }
},
"AddCut8": {
  "type": "AnalysisCut",
  "AddCut1": { "var": "kTPCnSigmaEl", "cutLow": -2.0, "cutHigh": 4.0 }
},
"AddCut9": {
  "type": "AnalysisCut",
  "AddCut1": { "var": "kTOFbeta", "cutLow": 0.95, "cutHigh": 1.05 }
},
"AddCut10": {
  "type": "AnalysisCut",
  "AddCut1": {
    "var": "kTPCnSigmaPr",
    "cutLow": 3.3,
    "cutHigh": 1000.0,
    "exclude": false,
    "dependentVar": "kHasTOF",
    "depCutLow": -0.5,
    "depCutHigh": 0.5
  }
}
